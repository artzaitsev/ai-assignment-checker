# ai-assignment-checker environment example

# =========================================================
# A) Already used by the current project (runtime + tests)
# =========================================================

# Postgres DSN for runtime repository wiring.
# If not set, runtime uses the in-memory repository.
DATABASE_URL=postgres://app:app@localhost:5432/app

# Integration tests resolve DSN in this order:
# TEST_DATABASE_URL -> DATABASE_URL -> built-in localhost default.
TEST_DATABASE_URL=

# Artifact repository versioning and compatibility policy.
ARTIFACT_CONTRACT_VERSION=v1
ARTIFACT_COMPAT_POLICY=strict

# Runtime host and role defaults.
# APP_ROLE is mainly used by reload/factory startup path.
APP_HOST=0.0.0.0
APP_ROLE=api

# Worker loop timing and lease configuration.
WORKER_POLL_INTERVAL_MS=200
WORKER_IDLE_BACKOFF_MS=1000
WORKER_ERROR_BACKOFF_MS=2000
WORKER_CLAIM_LEASE_SECONDS=30
WORKER_HEARTBEAT_INTERVAL_MS=10000


# =========================================================
# B) Already present in docker-compose (postgres container)
# =========================================================

# These are consumed by the postgres service in docker-compose.
# Python application code does not read these directly.
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app


# =========================================================
# C) Will be required for real integrations (not stubs)
# =========================================================

# S3-compatible storage client
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# Telegram Bot API client
TELEGRAM_BOT_TOKEN=

# OpenAI-compatible LLM client
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
