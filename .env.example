# Пример переменных окружения для ai-assignment-checker

# =========================================================
# A) Уже используются в текущем проекте (runtime + tests)
# =========================================================

# Postgres DSN для wiring runtime-репозитория.
# Если не задано, runtime использует in-memory репозиторий.
DATABASE_URL=postgres://app:app@localhost:5432/app

# Integration tests резолвят DSN в таком порядке:
# TEST_DATABASE_URL -> DATABASE_URL -> встроенный localhost default.
TEST_DATABASE_URL=

# Версия контракта артефактов и политика совместимости.
ARTIFACT_CONTRACT_VERSION=v1
ARTIFACT_COMPAT_POLICY=strict

# Дефолтные host и role для runtime.
# APP_ROLE в основном используется в reload/factory startup path.
APP_HOST=0.0.0.0
APP_ROLE=api

# Режим валидации runtime-конфига:
# - dev: локально-дружественные дефолты для stub runtime
# - strict: fail-fast на отсутствующих обязательных runtime-зависимостях
RUNTIME_VALIDATION_MODE=dev

# `.env` загружается при старте, если файл существует.
# Приоритет: process environment variables переопределяют значения из `.env`.

# Тайминги worker loop и конфигурация lease.
WORKER_POLL_INTERVAL_MS=200
WORKER_IDLE_BACKOFF_MS=1000
WORKER_ERROR_BACKOFF_MS=2000
WORKER_CLAIM_LEASE_SECONDS=30
WORKER_HEARTBEAT_INTERVAL_MS=10000

# Настройки брокера Telegram entrypoint-ссылки.
PUBLIC_WEB_BASE_URL=http://localhost:8000
TELEGRAM_LINK_SIGNING_SECRET=dev-telegram-link-secret
TELEGRAM_LINK_TTL_SECONDS=900

# Настройки сессии candidate apply.
APPLY_SESSION_SIGNING_SECRET=dev-apply-session-secret
APPLY_SESSION_TTL_SECONDS=900


# =========================================================
# B) Уже присутствуют в docker-compose (postgres container)
# =========================================================

# Эти переменные используются postgres-сервисом в docker-compose.
# Python application code не читает их напрямую.
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app


# =========================================================
# C) Понадобятся для реальных интеграций (не stubs)
# =========================================================

# S3-compatible storage client
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# Telegram Bot API client
TELEGRAM_BOT_TOKEN=

# OpenAI-compatible LLM client
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Требования strict mode по ролям (высокоуровнево):
# - api: DATABASE_URL
# - worker-ingest-telegram: DATABASE_URL + TELEGRAM_BOT_TOKEN
# - worker-normalize: DATABASE_URL + обязательные значения S3_*
# - worker-evaluate: DATABASE_URL + обязательные значения LLM_*
# - worker-deliver: DATABASE_URL + TELEGRAM_BOT_TOKEN
